# OpenAI API (의도분류·대화용 LLM)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# LangGraph 스트리밍 로그 (travel_agent.langgraph)
# 루트: 다른 라이브러리 노이즈 조절
TRAVEL_AGENT_LOG_LEVEL=INFO
# LangGraph stream 상세([LG debug], [LG values]). 기본 DEBUG면 터미널에 스트림 로그 출력.
# 줄이려면 INFO (노드 델타 [LG update] 위주).
TRAVEL_AGENT_LANGGRAPH_LOG_LEVEL=DEBUG
# 로그 한 줄에 넣는 JSON 최대 길이(문자)
TRAVEL_AGENT_LOG_PREVIEW=800
