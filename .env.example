# OpenAI API (의도분류·대화용 LLM)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# LangGraph 스트리밍 로그 (travel_agent.langgraph)
# 기본은 외부/라이브러리 로그를 거의 숨기고, LangGraph stream 로그만 출력
TRAVEL_AGENT_LOG_LEVEL=WARNING
# 기본 INFO면 핵심 업데이트만, DEBUG면 task/input/result와 values까지 표시
TRAVEL_AGENT_LANGGRAPH_LOG_LEVEL=INFO
# 로그 한 줄 미리보기 최대 길이(문자)
TRAVEL_AGENT_LOG_PREVIEW=240

# OPENWEATHER 서비스 API 키
OPENWEATHER_API_KEY=your-key-here

# SerpApi Google Flights API 키
flight_serpapi_api_key=your-serpapi-key-here
