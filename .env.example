# OpenAI API
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# LangGraph streaming logs (travel_agent.langgraph)
TRAVEL_AGENT_LOG_LEVEL=WARNING
TRAVEL_AGENT_LANGGRAPH_LOG_LEVEL=INFO
TRAVEL_AGENT_LOG_PREVIEW=240

# OpenWeather API
OPENWEATHER_API_KEY=your-key-here

# SerpApi
# Hotel and flight can share the same SerpApi key.
SERPAPI_API_KEY=your-serpapi-key-here

# Backward-compatible alias for the flight path
flight_serpapi_api_key=your-serpapi-key-here
